{
  "name": "supashiphq/php-sdk",
  "description": "Supaship SDK for PHP",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "supaship",
    "php",
    "sdk"
  ],
  "homepage": "https://supaship.com",
  "support": {
    "issues": "https://github.com/SupashipHQ/sdk/issues",
    "source": "https://github.com/SupashipHQ/sdk/tree/main/packages/php"
  },
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Supaship\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Supaship\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:coverage": "phpunit --configuration phpunit.xml.dist --coverage-text",
    "check:composer": "composer validate --strict"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
