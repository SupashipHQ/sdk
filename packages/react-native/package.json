{
  "name": "@supashiphq/react-native-sdk",
  "version": "1.1.0",
  "description": "Supaship SDK for React Native",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && pnpm build:tsup",
    "build:tsup": "tsup",
    "dev": "tsup --watch",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.71.0"
  },
  "dependencies": {
    "@supashiphq/javascript-sdk": "workspace:^1.1.0",
    "@supashiphq/react-core": "workspace:^1.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.0",
    "typescript": "~5.3.3"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "react-native",
    "sdk"
  ],
  "author": "Supaship",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SupashipHQ/javascript-sdk",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/SupashipHQ/javascript-sdk/issues"
  },
  "homepage": "https://supaship.com",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
