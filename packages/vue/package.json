{
  "name": "@supashiphq/vue-sdk",
  "version": "1.0.2",
  "description": "Supaship SDK for Vue 3",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && pnpm build:tsup",
    "build:tsup": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "dependencies": {
    "@supashiphq/javascript-sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "vue",
    "vue3",
    "sdk"
  ],
  "author": "Supaship",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SupashipHQ/javascript-sdk",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/SupashipHQ/javascript-sdk/issues"
  },
  "homepage": "https://supaship.com",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
