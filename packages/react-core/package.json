{
  "name": "@supashiphq/react-core",
  "version": "1.1.0",
  "description": "Shared React primitives for Supaship web and React Native SDKs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./focus-web": {
      "types": "./dist/focus-web.d.ts",
      "import": "./dist/focus-web.mjs",
      "require": "./dist/focus-web.js"
    },
    "./focus-native": {
      "types": "./dist/focus-native.d.ts",
      "import": "./dist/focus-native.mjs",
      "require": "./dist/focus-native.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && pnpm build:tsup",
    "build:tsup": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "@supashiphq/javascript-sdk": "workspace:^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "react": "^18.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "~5.3.3"
  },
  "keywords": [
    "feature-flags",
    "react",
    "supaship"
  ],
  "author": "Supaship",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SupashipHQ/javascript-sdk",
    "directory": "packages/react-core"
  },
  "bugs": {
    "url": "https://github.com/SupashipHQ/javascript-sdk/issues"
  },
  "homepage": "https://supaship.com",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
